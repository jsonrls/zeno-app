# Maintenance Mode Configuration
# Set to 'true' to enable maintenance mode
# Set to 'false' or remove this line to disable maintenance mode
MAINTENANCE_MODE=false

# Supabase browser configuration. These values are safe to expose to the
# browser, but must be supplied for every environment.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key

# Optional: enables deliverability checks in the problem-report form.
NEXT_PUBLIC_ABSTRACT_EMAIL_API_KEY=
